    <nav class="nav">
      <a href="/about">about</a>
      <a href="/projects">projects</a>
      <a href="/notes">notes</a>
      <a href="/music">music</a>
      <a href="/cv">cv</a>
      <a href="https://github.com/alpblkba">github</a>
    </nav>
  </section>

  <section>
    <h2>current direction</h2>

    <pre>{`ops stuff
    ↓
low-level / embedded development
    ↓
digital design
    ↓
hardware-software co-design
    ↓
somewhere between the debugger and the datasheet`}</pre>
  </section>

  <section>
    <h2>average hardware-software co-design enjoyer</h2>


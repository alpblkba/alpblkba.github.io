---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="alpblkba">
  <section class="hero">
    <h1 class="site-name">alpblkba</h1>

    <p class="subtitle">
      systems · embedded · computer architecture · hardware-aware software
    </p>

    <p>
      I like software that gets close enough to the machine to make abstractions nervous.
    </p>

    <nav class="nav">
      <a href="/about">about</a>
      <a href="/projects">projects</a>
      <a href="/notes">notes</a>
      <a href="/music">music</a>
      <a href="/cv">cv</a>
      <a href="https://github.com/alpblkba">github</a>
    </nav>
  </section>

  <section>
    <h2>current direction</h2>

    <pre>{`ops stuff
    ↓
low-level / embedded development
    ↓
digital design
    ↓
hardware-software co-design
    ↓
somewhere between the debugger and the datasheet`}</pre>
  </section>

<section class="latest-notes">
  <h2>latest</h2>

  <div class="latest-note-list">
    <a class="latest-note" href="/notes/aes-cpa-on-fpga">
          <span class="latest-note-date">2026-07-15</span>
          <span class="latest-note-title">Correlation Power Analysis on AES with an FPGA Sensor</span>
        </a>
  </div>
</section>

  <section>
    <h2>selected work</h2>

    <div class="card-grid">
      <article class="card">
        <h3>rv32i-mla</h3>
        <p>
          RV32I CPU and accelerator experiments on PYNQ, written in Verilog.
        </p>
        <a href="/projects">view projects</a>
      </article>

      <article class="card">
        <h3>hardware-security</h3>
        <p>
          FPGA-based hardware security tasks, PUF experiments, and low-level security concepts.
        </p>
        <a href="/projects">view projects</a>
      </article>

      <article class="card">
        <h3>iot-lab</h3>
        <p>
          Embedded systems lab work with STM32, C/C++, UART/GPIO bring-up, and device-level debugging.
        </p>
        <a href="/projects">view projects</a>
      </article>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";

const notes = [
  
  {
    title: "Correlation Power Analysis on AES with an FPGA Sensor",
    date: "2026-07-15",
    href: "/notes/aes-cpa-on-fpga",
  },
{
    title: "AES-128 on an iCE40 FPGA",
    date: "2026-07-08",
    href: "/notes/aes-on-hardware",
  },
  {
    title: "SRAM Weak PUF Readout on iCE40",
    date: "2026-06-07",
    href: "/notes/sram-weak-puf-readout",
  },
];---

<BaseLayout title="notes">
  <main class="notes-page">
    <h1>notes</h1>

    <p class="notes-intro">
      engineering notes, lab logs, paper notes, and small technical writeups.
    </p>

    <section class="notes-list">
      {notes.map((note) => (
        <a class="note-card" href={note.href}>
          <span class="note-date">{note.date}</span>
          <span class="note-title">{note.title}</span>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
